{
  "name": "gridwalker-server",
  "version": "1.0.0",
  "description": "Gridwalker GPS-based city MMO - Backend Server",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:init": "psql $DATABASE_URL -f src/db/schema.sql",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "gridwalker",
    "gps",
    "mmo",
    "city",
    "game"
  ],
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "express": "^4.21.1",
    "express-ws": "^5.0.2",
    "cors": "^2.8.5",
    "helmet": "^8.0.0",
    "morgan": "^1.10.0",
    "compression": "^1.7.5",
    "pg": "^8.13.1",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "node-cron": "^3.0.3",
    "multer": "^1.4.5-lts.1",
    "uuid": "^10.0.0",
    "axios": "^1.7.9",
    "zod": "^3.24.1",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "ts-node": "^10.9.2",
    "nodemon": "^3.1.9",
    "@types/express": "^5.0.0",
    "@types/express-ws": "^3.0.5",
    "@types/cors": "^2.8.17",
    "@types/morgan": "^1.9.9",
    "@types/compression": "^1.7.5",
    "@types/pg": "^8.11.10",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/bcryptjs": "^2.4.6",
    "@types/node-cron": "^3.0.11",
    "@types/multer": "^1.4.12",
    "@types/uuid": "^10.0.0",
    "@types/node": "^22.10.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
