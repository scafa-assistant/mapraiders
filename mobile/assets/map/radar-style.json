{
  "version": 8,
  "name": "MapRaiders Radar",
  "metadata": {
    "note": "Commander radar look: white land, blue water, green woods, no labels/POI/roads. OpenFreeMap vector tiles (free, no key). Colors mirror utils/commander RADAR_MAP_STYLE + brand off-white."
  },
  "glyphs": "https://tiles.openfreemap.org/fonts/{fontstack}/{range}.pbf",
  "sources": {
    "openmaptiles": {
      "type": "vector",
      "url": "https://tiles.openfreemap.org/planet"
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": { "background-color": "#F6F4F1" }
    },
    {
      "id": "park",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "park",
      "filter": ["==", "$type", "Polygon"],
      "paint": { "fill-color": "#DCE8D6", "fill-opacity": 0.7 }
    },
    {
      "id": "landcover_wood",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "filter": ["==", "class", "wood"],
      "paint": { "fill-color": "#DCE8D6", "fill-opacity": 0.6 }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "water",
      "filter": ["!=", "brunnel", "tunnel"],
      "paint": { "fill-color": "#C7DBF2" }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "waterway",
      "paint": { "line-color": "#B4CDEC", "line-width": 1.2 }
    },
    {
      "id": "roads-casing",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["all", ["!=", "class", "rail"], ["!in", "class", "path", "track"]],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#D8D2C8",
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          12, ["match", ["get", "class"], ["motorway", "trunk"], 4.6, ["primary"], 3.6, 2.4],
          17, ["match", ["get", "class"], ["motorway", "trunk"], 11.5, ["primary"], 9.5, ["secondary"], 7.5, 6]
        ]
      }
    },
    {
      "id": "roads",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["!=", "class", "rail"],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": [
          "match", ["get", "class"],
          ["path", "track"], "#C6A77E",
          "#FFFFFF"
        ],
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          12, ["match", ["get", "class"], ["motorway", "trunk"], 3, ["primary"], 2.2, ["path", "track"], 0.8, 1.2],
          17, ["match", ["get", "class"], ["motorway", "trunk"], 9, ["primary"], 7, ["secondary"], 5.5, ["path", "track"], 2, 4]
        ]
      }
    }
  ]
}
