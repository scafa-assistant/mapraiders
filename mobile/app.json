{
  "expo": {
    "name": "MapRaiders",
    "slug": "mapraiders",
    "scheme": "mapraiders",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0E17"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.mapraiders.app",
      "infoPlist": {
        "NSLocationAlwaysAndWhenInUseUsageDescription": "MapRaiders needs your location to track your movement, claim territories, and discover nearby quests and echoes.",
        "NSLocationWhenInUseUsageDescription": "MapRaiders needs your location to show your position on the map and find nearby content.",
        "NSLocationAlwaysUsageDescription": "MapRaiders uses background location to track your route while walking, running, or cycling.",
        "NSCameraUsageDescription": "MapRaiders needs camera access to complete quest verification steps and capture proof.",
        "NSMicrophoneUsageDescription": "MapRaiders needs microphone access to record audio echoes and video challenges.",
        "UIBackgroundModes": [
          "location",
          "fetch",
          "remote-notification"
        ]
      },
      "config": {
        "googleMapsApiKey": "AIzaSyBB2e7HDOhSIsOvNOM7QA6pgCyFkHQgs0U"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0E17"
      },
      "package": "com.mapraiders.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "CAMERA",
        "RECORD_AUDIO",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBB2e7HDOhSIsOvNOM7QA6pgCyFkHQgs0U"
        }
      }
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "MapRaiders needs your location to track movement and claim territories.",
          "isAndroidBackgroundLocationEnabled": true
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "MapRaiders needs camera access for quest verification."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#00D4FF"
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "MapRaiders needs microphone access to record echoes."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "11263b5c-0b4f-4039-bc2a-9f9ebe3c0769"
      }
    },
    "owner": "iveezee23s-organization"
  }
}
